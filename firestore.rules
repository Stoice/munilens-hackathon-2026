rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        ((exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin') ||
         (request.auth.token.email == "willselepe21@gmail.com" && request.auth.token.email_verified == true));
    }

    function isEnabled() {
      return isAuthenticated() && 
        (!exists(/databases/$(database)/documents/users/$(request.auth.uid)) || 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('enabled', true) == true);
    }

    function isValidReport(data) {
      return data.type is string && 
             data.type in ["Pothole", "Water Leak", "Broken Streetlight", "Illegal Dumping", "Electricity Outage", "Electrical Damage", "Other"] &&
             data.latitude is number &&
             data.longitude is number &&
             data.status in ["Open", "In Progress", "Resolved"] &&
             data.reporterUid == request.auth.uid &&
             data.reportedAt is string &&
             data.importance is string &&
             data.routedTo is string &&
             data.estimatedSolution is string &&
             (!('photoUrl' in data) || data.photoUrl is string) &&
             (!('description' in data) || (data.description is string && data.description.size() < 1000)) &&
             (!('address' in data) || data.address is string);
    }

    function isValidUser(data) {
      return data.uid is string &&
             data.email is string &&
             data.role in ["citizen", "admin"] &&
             (!('displayName' in data) || data.displayName is string);
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId) && isValidUser(request.resource.data) && 
                      (request.resource.data.role == 'citizen' || 
                       (request.resource.data.role == 'admin' && request.auth.token.email == "willselepe21@gmail.com"));
      allow update: if (isOwner(userId) && request.resource.data.role == resource.data.role && request.resource.data.enabled == resource.data.enabled) || isAdmin();
    }

    match /reports/{reportId} {
      allow read: if isAdmin() || (isAuthenticated() && resource.data.reporterUid == request.auth.uid);
      allow create: if isAuthenticated() && isValidReport(request.resource.data);
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }
  }
}
